{
  "title": "__SERVICE_NAME__",
  "tags": ["nodejs", "api", "__TEAM_NAME__"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Availability",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "avg(up{job=\"__SERVICE_NAME__\"})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Rate",
      "gridPos": { "x": 6, "y": 0, "w": 9, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"__SERVICE_NAME__\"}[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU Usage",
      "gridPos": { "x": 0, "y": 6, "w": 9, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{pod=~\"__SERVICE_NAME__.*\"}[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": { "x": 9, "y": 6, "w": 9, "h": 6 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{pod=~\"__SERVICE_NAME__.*\"})"
        }
      ]
    }
  ]
}
